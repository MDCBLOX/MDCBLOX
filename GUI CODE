        // Kart Oluşturma Fonksiyonu
        function createCard(project) {
            const dateStr = project.date.toLocaleDateString('tr-TR');
            const timeStr = project.date.toLocaleTimeString('tr-TR', {hour: '2-digit', minute:'2-digit'});
            const visClass = project.visibility === 'public' ? 'visibility-public' : 'visibility-private';
            const visText = project.visibility === 'public' ? '🌐 Herkese Açık' : '🔒 Özel';

            return `
                <div class="content-card" data-id="${project.id}" data-name="${project.name.toLowerCase()}" data-visibility="${project.visibility}" data-date="${project.date.getTime()}">
                    <div class="card-header">
                        <div class="card-title">${project.name}</div>
                        <div class="visibility-badge ${visClass}">${visText}</div>
                    </div>
                    <div class="card-meta">
                        <span>📅 ${dateStr}</span>
                        <span>🕐 ${timeStr}</span>
                    </div>
                    <div class="card-description">${project.description}</div>
                    <div class="card-actions">
                        <button class="btn btn-small" onclick="viewProject(${project.id})">👁 Görüntüle</button>
                        <button class="btn btn-purple btn-small" onclick="editProject(${project.id})">✏ Düzenle</button>
                    </div>
                </div>
            `;
        }

        // Kartları Render Et
        function renderCards() {
            const grid = document.getElementById('contentGrid');
            grid.innerHTML = projects.map(p => createCard(p)).join('');
        }

        // Filtreleme Sistemi
        function applyFilters() {
            const nameFilter = document.getElementById('nameFilter').value.toLowerCase();
            const timeFilter = document.getElementById('timeFilter').value;
            const visibilityFilter = document.getElementById('visibilityFilter').value;

            const cards = document.querySelectorAll('.content-card');
            const now = Date.now();

            cards.forEach(card => {
                const name = card.getAttribute('data-name');
                const visibility = card.getAttribute('data-visibility');
                const date = parseInt(card.getAttribute('data-date'));

                let show = true;

                // İsim filtresi
                if (nameFilter && !name.includes(nameFilter)) {
                    show = false;
                }

                // Zaman filtresi
                if (timeFilter !== 'all') {
                    const diff = now - date;
                    const day = 86400000;
                    const week = day * 7;
                    const month = day * 30;
                    const year = day * 365;

                    switch(timeFilter) {
                        case 'today':
                            if (diff > day) show = false;
                            break;
                        case 'week':
                            if (diff > week) show = false;
                            break;
                        case 'month':
                            if (diff > month) show = false;
                            break;
                        case 'year':
                            if (diff > year) show = false;
                            break;
                    }
                }

                // Görünürlük filtresi
                if (visibilityFilter !== 'all' && visibility !== visibilityFilter) {
                    show = false;
                }

                if (show) {
                    card.classList.remove('hidden');
                    // Staggered animation
                    card.style.animation = 'none';
                    setTimeout(() => {
                        card.style.animation = 'fadeIn 0.5s ease forwards';
                    }, 50);
                } else {
                    card.classList.add('hidden');
                }
            });
        }

        // Özel Script Çalıştırma
        function runCustomScript() {
            const code = document.getElementById('customScript').value;
            const statusText = document.getElementById('statusText');
            const lastRun = document.getElementById('lastRun');

            statusText.innerHTML = '<span class="loading"></span> Çalıştırılıyor...';

            try {
                // Güvenli eval - strict mode ile
                const wrappedCode = `
                    "use strict";
                    (function() {
                        ${code}
                    })();
                `;
                
                eval(wrappedCode);
                
                statusText.innerHTML = '✅ Kod başarıyla çalıştırıldı!';
                statusText.style.color = '#00ff88';
                lastRun.textContent = 'Son çalışma: ' + new Date().toLocaleTimeString('tr-TR');

                // 3 saniye sonra normale dön
                setTimeout(() => {
                    statusText.innerHTML = 'Hazır - Kodları düzenleyip çalıştırabilirsiniz';
                    statusText.style.color = '#fff';
                }, 3000);

            } catch (error) {
                statusText.innerHTML = '❌ Hata: ' + error.message;
                statusText.style.color = '#ff006e';
                console.error('Script Error:', error);
            }
        }

        // Yardımcı Fonksiyonlar
        function showAlert(text) {
            // Glow efektli alert
            const alertDiv = document.createElement('div');
            alertDiv.style.cssText = `
                position: fixed;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                background: rgba(10, 10, 15, 0.95);
                border: 2px solid var(--neon-blue);
                border-radius: 20px;
                padding: 40px;
                box-shadow: 0 0 60px rgba(0, 243, 255, 0.5);
                z-index: 1000;
                text-align: center;
                backdrop-filter: blur(20px);
                animation: popIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            `;
            alertDiv.innerHTML = `
                <h2 style="color: var(--neon-blue); margin-bottom: 20px; text-shadow: 0 0 20px rgba(0,243,255,0.5);">${text}</h2>
                <p style="margin-bottom: 30px; color: rgba(255,255,255,0.8);">Bu özellik yakında aktif olacak!</p>
                <button class="btn" onclick="this.parentElement.remove(); document.getElementById('overlay').remove();">Tamam</button>
            `;
            
            const overlay = document.createElement('div');
            overlay.id = 'overlay';
            overlay.style.cssText = `
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: rgba(0,0,0,0.7);
                z-index: 999;
                backdrop-filter: blur(5px);
            `;
            
            document.body.appendChild(overlay);
            document.body.appendChild(alertDiv);
        }

        function viewProject(id) {
            const project = projects.find(p => p.id === id);
            showAlert(`Proje: ${project.name}`);
        }

        function editProject(id) {
            const project = projects.find(p => p.id === id);
            showAlert(`Düzenleniyor: ${project.name}`);
        }

        function toggleTheme() {
            document.body.style.filter = document.body.style.filter === 'hue-rotate(180deg)' ? '' : 'hue-rotate(180deg)';
        }

        // CSS Animasyon ekle
        const style = document.createElement('style');
        style.textContent = `
            @keyframes fadeIn {
                from { opacity: 0; transform: translateY(20px); }
                to { opacity: 1; transform: translateY(0); }
            }
            @keyframes popIn {
                from { opacity: 0; transform: translate(-50%, -50%) scale(0.5); }
                to { opacity: 1; transform: translate(-50%, -50%) scale(1); }
            }
        `;
